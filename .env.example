# —— Required (local + Vercel) ——

# Postgres connection string.
# Local Docker: see docker-compose.yml
# Neon / Vercel: `npx neonctl@latest env pull` writes pooled DATABASE_URL
# (and DATABASE_URL_UNPOOLED) into .env.local — copy the pooled URL to Vercel.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jembatan

# Neon branch label (written by `neon env pull`; optional)
# NEON_BRANCH=production

# Neon direct (non-pooler) URL — preferred for migrate/seed locally.
# DATABASE_URL_UNPOOLED=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
# Must be set in Vercel Production and Preview.
AUTH_SECRET=replace-with-a-long-random-string

# Public site URL (set on Vercel, e.g. https://jembatan.vercel.app)
AUTH_URL=http://localhost:3000

# —— Sentry (optional but recommended in production) ——

# Server / edge DSN
# SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# Browser DSN (often same value; expose to the client)
# NEXT_PUBLIC_SENTRY_DSN=https://xxxx@o0.ingest.sentry.io/0

# Source map upload on Vercel builds (Settings → Auth Tokens)
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=jembatan

# —— Local seed only (not needed on Vercel runtime) ——

# SEED_USER_EMAIL=belajar@jembatan.app
# SEED_USER_PASSWORD=belajar123
# SEED_USER_NAME=Pembelajar

# —— Card audio (local generate only; not needed on Vercel) ——

# Google Cloud service-account JSON for `npm run audio:generate`.
# Enable Cloud Text-to-Speech API on the project first.
# Keep keys in gcp-keys/ (gitignored). Example:
# GOOGLE_APPLICATION_CREDENTIALS=/Users/you/Documents/projects/jembatan/gcp-keys/your-key.json
# Alternative: `gcloud auth application-default login`
