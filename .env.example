# Postgres connection string (local Docker or Neon / Vercel Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jembatan

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-long-random-string

# Optional: public URL in production (e.g. https://jembatan.vercel.app)
# AUTH_URL=http://localhost:3000

# Optional: create this user on seed if set
# SEED_USER_EMAIL=belajar@jembatan.app
# SEED_USER_PASSWORD=ganti-password-ini
# SEED_USER_NAME=Pembelajar
